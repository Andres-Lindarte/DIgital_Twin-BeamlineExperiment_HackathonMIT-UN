particles {
  coordinates = 0,
  standard_beam {
    n = 5000,
    tob = gaussian_distribution {
      mean = 2,
      fwhm = 1
    },
    mass = 100,
    charge = 1,
    ke = 0.1,
    az = 0,
    el = 0,
    cwf = 1,
    color = 1,
    position = circle_distribution {
      center = vector(5, 0, 0),
      normal = vector(1, 0, 0),
      radius = 5,
      fill = true
    }
  }
}
