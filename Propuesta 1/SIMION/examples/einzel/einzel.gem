; einzel.gem
; Einzel lens. 2D or 3D (using fill/rotate_fill)

pa_define(91,20,1, cylindrical,, electrostatic)  ; 2D
; pa_define(91,20,20, planar,yz, electrostatic)  ; 3D

e(1) { rotate_fill(360) { within { box( 0,18, 28,19) } } }
e(2) { rotate_fill(360) { within { box(30,18, 56,19) } } }
e(3) { rotate_fill(360) { within { box(58,18, 90,19) } } }

; Note: "fill" would work just as well as "rotate_fill" in the
; 2D case, though the latter works in both 2D and 3D cases.
