; tilted_plates3d.gem
; two parallel plates tiled at small angle (2.86 degrees), 3D,
; WITH surface enhancement

pa_define(25,41,41,planar,non-mirrored, surface=fractional)
locate(11,20,0, 1, 2.86,2.86) {
  e(1) { fill { within { box2d(-20, -1000, -10, 1000) }}}
  e(2) { fill { within { box2d( 20, -1000,  10, 1000) }}}
}

