; kingdon_1dc.gem
; two infinitely long concentric cylinders (2D cylindrical symmetry),
; generating a purely logarithmic potential.

# local r1 = 8  -- mm
# local r2 = 20 -- mm
# local scale = 0.1   -- mm/gu scale
# local r2outer = r2 + 2*scale
#
# local ny = r2outer / scale + 1

pa_define(3,$(ny),1, cylindrical,xy,electric,, $(scale*10),$(scale))

e(1) { fill { within { box(0,0, 1e6,$(r1)) } } }
e(2) { fill { within { box(0,$(r2), 1e6,1e6) } } }
