; makes hyperbolic trap.
pa_define(2401,1201,1,cylindrical,y)

locate(1200)
  {
  e(1000)  ; y hyperbola - ring
    {
    fill
      {
      within{hyperbola(0,0,282.8,400)}
      ; width is 0.19 times ring diameter
      notin{box2d(-76,0,76,1e6)}  ; ring slot
      }
    }

  e(0)   ; side hyperbola - caps
    {
    fill
      {
      within{locate(,,,,,90){hyperbola(0,0,400,282.8)}}
      }
    }
  }
