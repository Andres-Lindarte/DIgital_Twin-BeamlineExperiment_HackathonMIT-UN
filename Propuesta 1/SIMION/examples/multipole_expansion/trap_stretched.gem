; makes hyperbolic trap.
pa_define(2401,1201,1,cylindrical,y)

locate(1200)
  {
  e(1000)  ; y hyperbola - ring
    {
    fill{within{hyperbola(0,0,282.8,400)}}
    }

  e(0)   ; side hyperbola - caps
    {
    fill
      {
      ; z0 increased by 10.8% for stretched trap.
      within{locate(-30.54,,,,,90){hyperbola(0,0,400,282.8) box2d(0,0,1e6,1e6)}}
      within{locate( 30.54,,,,,90){hyperbola(0,0,400,282.8) box2d(0,0,1e6,-1e6)}}
      }
    }
  }
