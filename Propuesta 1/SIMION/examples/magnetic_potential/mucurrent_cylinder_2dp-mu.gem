; Creates relative permeability PA.

pa_define(200,400,1, planar,x,magnetic_,, 0.5,0.5,0.5)  ; 0.5 mm/gu

; First fill all space by default with relative permeability 1.
n(1) {
  fill { within { box3d(-1E+6,-1E+6,-1E+6, 1E+6,1E+6,1E+6) } }
}

; Fill a cylinder with > 1 constant.
locate(-0.25,-0.25,-0.25) { ; shift down by 1/2 grid unit (see README)
  n(0.2) { fill { within_inside { circle(0,100, 10) } } }
}

