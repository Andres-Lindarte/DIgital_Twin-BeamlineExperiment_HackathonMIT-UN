; For two coaxial magnetized cylinders example.
; GEM file creating PA in which to store M_x,
; i.e. x component of magnetization vector.

pa_define(800,400,1, cylindrical,none,magnetic_,, 0.25,0.25,0.25)  ; mm/gu

; magnetization (M) in units A/mm.
# local M = 1

locate(-0.125,-0.125,-0.125) { ; shift down by 1/2 grid unit (see README)
  n($(M)){ fill { within_inside { box(75,0, 95,20) } } }
  n($(M)){ fill { within_inside { box(105,0, 125,20) } } }
}
