; current density for C-magnet.
; user program may rescale these.

pa_define(250,200,1, planar,y,magnetic_,1, 1,1,1) ; /mm/gu

# local gap = _G.gap or 30

locate(-0.5,-0.5,-0.5) { ; 0.5 gu shift (see README)

locate(0,$(gap),0) {

n(1) {
  fill {
    within_inside { box(100,0, 150,50) }
  }
}
n(-1) {
  fill {
    within_inside { box(100,100, 150,150) }
  }
}

}

}
