; Creates relative permeability PA.

pa_define(100,100,100, planar,xyz,magnetic_,, 1,1,1)  ; mm/gu

; First fill all space by default with value 1.
n(1) {
  fill { within { box3d(-1E+6,-1E+6,-1E+6, 1E+6,1E+6,1E+6) } }
}

; Fill a sphere with value > 1.
locate(-0.5,-0.5,-0.5) { ; shift down by 1/2 grid unit (see README)
  n(5) { fill { within_inside { sphere(0,0,0, 10) } } }
}
