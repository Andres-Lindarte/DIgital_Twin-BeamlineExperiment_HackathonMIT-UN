; For two coaxial magnetized cylinders example.
; GEM file for magnetic scalar potential PA.
; This stores boundary conditions for Omega_H, where -grad Omega_H = H.
; Omega_H is calculated in this PA.

pa_define(801,401,1, cylindrical, none,magnetic_,, 0.25,0.25,0.25)  ; mm/gu

; Omega_H = 0 on outer boundaries (no flex across surfaces).
e(0) {
  edge_fill { within { box2d(0,-100, 200,100) } }
}

