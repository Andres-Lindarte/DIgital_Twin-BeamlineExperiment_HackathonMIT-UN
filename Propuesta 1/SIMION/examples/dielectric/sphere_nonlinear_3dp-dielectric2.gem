; Creates dielectric PA for use with nonlinear dielectric solving.
; This is initially empty.  The user program will will this
; with current valuse of relative dielectric constants
; based on local electric fields.

pa_define(200,100,100, planar,yz,electric_,, 0.5,0.5,0.5)  ; 0.5 mm/gu

; First fill all space by default with dielectric constant 1.
n(1) {
  fill { within { box3d(-1E+6,-1E+6,-1E+6, 1E+6,1E+6,1E+6) } }
}
