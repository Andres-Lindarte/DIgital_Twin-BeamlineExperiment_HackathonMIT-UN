;makes hyperbolic quad as fast adjust file

						;array to use with quad
pa_define(101,101,1,planar,xy_mirror)

e(1)					;electrode of one volt
{						;draw y hyperbola
fill{within{hyperbola(0,0,50,50)}}
}

e(2)					;electrode of two volts
{						;draw x hyperbola
fill{within{locate(,,,,,90){hyperbola(0,0,50,50)}}}
}
