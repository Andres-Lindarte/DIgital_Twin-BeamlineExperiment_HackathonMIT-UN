; draws cone
pa_define(51,51,51,planar,none,electrostatic)
electrode(1) {           ; voltage
  locate(10,25,25) {     ; translate position of cone (x,y,z)
    rotate_fill(360) {   ; degrees around x axis
      within {
        polyline( 0,0,   ; (x,y) verticies of triangle of cone.
                  0,15,
                  30,0 )
      }
    }
  }
}
