; Faraday cage of rings forming sphere.
; Cage is between an external field formed by two discs.

pa_define(501,251,1, cylindrical,,, 1)

; external field
e(-100) { fill { within { box2d(  0,0,   0,1E+6) } } }
e( 100) { fill { within { box2d(500,0, 500,1E+6) } } }

; Faraday cage of rings forming sphere.
# local N = 10
# local R = 125
# local x0,y0 = 250, 0
# for i=0,N do
#   local theta = (i/N) * math.pi
e(0) { fill { within { circle($(x0+R*cos(theta)), $(y0+R*sin(theta))) } } }
# end
