;;;;;;;;;;;;;;;;;;;; cma2d.gem ;;;;;;;;;;;;;;;;;;;;;;;;
; GEM file for 2-D example of idealized cylindrical mirror analyzer.
;
; This is quite similar in structure to
; parallel_plate_capacitor_2d.gem , so see comments in that
; file for details.  The main difference is that symmetry
; is "cylindrical".

pa_define(101, 51, 1, cylindrical, none, electrostatic)

; bottom plate
e(1) { fill { within { box2d(0,25, 100,25) } } }

; top plate
e(2) { fill { within { box2d(0,50, 100,50) } } }



