; uniform bfield.
; Unform magnetic field (ideal field without fringing effects).
; This is very similar in structure to parallel_plate_capacitor_2d.gem, so
; see comments in that file for further details.

# local xwidth = 100
# local ygap   = 50

pa_define($(xwidth+1), $(ygap+1), 1, planar, none, magnetic, $(ygap))

; bottom plate
e(1) { fill { within { box2d(0,0,   $(xwidth),0) } } }

; top plate
e(2) { fill { within { box2d(0,$(ygap), $(xwidth),$(ygap)) } } }
