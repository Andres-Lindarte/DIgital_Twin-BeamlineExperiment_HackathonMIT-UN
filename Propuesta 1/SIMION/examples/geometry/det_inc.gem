;creates detector on axis

rotate_fill()				;front end of detector
	{
	within{box(0,0,15,10)}	;front of detector
							;create cone shaped hole
	notin{polyline(0,0	12,0  0,8)}
	}
e(0)						;grounded back half of detector
	{
	rotate_fill()
		{					;create back half of detector
		within{box(16,0,35,10)}
		}
	}
