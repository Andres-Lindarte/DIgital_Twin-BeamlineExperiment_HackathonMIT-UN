			rotate_fill(180){					;create 1/2 volume of revolution
			   within{polyline( 0.000, 0.460,	;defines cross section of
								0.000, 0.660,	;mating collar
								0.840, 0.660,
								0.840, 0.570,
								1.340, 0.570,
								1.340, 0.460)}
				}
			}
		}
	}








; **********************************************************************
; ************************	Sample probe  ******************************
; **********************************************************************
locate(-9.76,0,0,1,-90)   ; swing back 90 deg cw in azimuth and
	{					  ; shift lens left 9.76" from origin.
	e(9)				  ; create with 9 volt electrode points
		{
		locate(0,0,0,1,90)			;swing 90 deg ccw in azimuth
			{
			rotate_fill(180){					;create 1/2 volume of revolution
			   within{polyline( 0.000, 0.500,	;defines cross section of
								0.190, 0.500,	;sample probe
								0.190, 0.450,
								0.310, 0.450,
								0.410, 0.350,
								0.410, 0.170,
								1.610, 0.170,
								1.610, 0.110,
								2.260, 0.110,
								2.510, 0.025,
								2.510, 0.000,
								0.000, 0.000)}
				}
			}
		}
	}









; **********************************************************************
; *****************************  Sample ********************************
; **********************************************************************
locate(-6.8,0,0,1,-90)	 ; swing 90 deg cw in azimuth and
	{					 ; shift lens left 6.8" from origin.
	e(5)				 ; create with 5 volt electrode points
		{
		fill{
			within{cylinder(0,0,.45,.030,,.45)} ;sample tube
			}
		}
	}









