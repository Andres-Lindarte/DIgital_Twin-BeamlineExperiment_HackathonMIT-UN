			  within{cylinder(0,0,.180,0.06,,0.18)} ;insulator collar
			  within{cylinder(0,0,0,0.1,,0.020)}	;insulator color flange
			  }
			 }
			locate(0,0,0,1,0,-90)  ;front filament post (swing 90 deg cw in elevation)
			 {
