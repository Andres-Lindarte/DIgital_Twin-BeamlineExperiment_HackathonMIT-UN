;Pa_define(200,50,50,p,yz)	 ;1/4 volume pa -- 10 mill resolution
Pa_define(200,50,101,p,y)  ;1/2 volume pa -- 10 mill resolution

;Locate(0,0,0,100)	   ;project real volume into potential array (scale = 100 gu/inch)
Locate(0,0,50,100)	 ;project real volume into potential array (scale = 100 gu/inch)
	{
	locate(.2,0,0,1)
		{
		e(1){rotate_fill(360){within{polyline(0,.25,.25,.30,.5,.5,0,.5)}}}
		}
	locate(1.5,0,0,1,45)
		{
		e(2){rotate_fill(360){within{circle(0,.4,.1)}}}
		}
	}


