pa_define(39,39,,p,xy)		; 39x, 39y, 1z 2D Planar xy mirrored

; scaled for 0.2 mm/grid unit
; r0 = 20  r = 23  based on r = 1.1487 r0

e(2)						; electrode number 2
	{						; fill top rod
	fill{within{circle(0,43,23)}}
	}

e(1)						; electrode number 1
	{						; fill right rod
	fill{within{circle(43,0,23)}}
	}
